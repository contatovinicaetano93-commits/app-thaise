# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legado (opcional — use publishable se disponível)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — Settings → API → Secret / service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Database direct (Settings → Database → Connection string → URI) — para npm run setup
DATABASE_URL=

# Seed do usuário gestor (npm run seed)
SEED_GESTOR_EMAIL=thaise@plataforma.com
SEED_GESTOR_PASSWORD=


# Redis Upstash — https://console.upstash.com → Redis URL (rediss://...)
# Sem isso, jobs rodam inline na API (OK para MVP)
REDIS_URL=
# Só use fila BullMQ com worker dedicado (npm run worker)
USE_BULLMQ=

# Anthropic — preferencial (insights QCPS, resumos, relatório mensal)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — fallback opcional
OPENAI_API_KEY=

# Cron Vercel — relatório 360 semanal (Estlar EOS)
CRON_SECRET=

# E-mail transacional — https://resend.com
# Conta Resend: contato.vinicaetano93@gmail.com
# Sem domínio: use Estlar <onboarding@resend.dev> (só envia para o e-mail da conta Resend)
RESEND_API_KEY=
EMAIL_FROM=Estlar <onboarding@resend.dev>

# WhatsApp — Evolution API (opcional; sem API gera link wa.me para envio manual)
# Número Estlar: +55 11 99345-5589
WHATSAPP_FROM_NUMBER=5511993455589
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=estlar

# URL pública do app (links nos e-mails de convite)
# Modo simples (default): menu enxuto + dashboard focado no fluxo canonico
# Desativar para menu completo (Insights, SIPOC, API Docs, etc.):
# NEXT_PUBLIC_SIMPLE_MODE=0

NEXT_PUBLIC_APP_URL=

# Sentry — https://sentry.io (opcional; sem DSN o SDK fica inativo)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Opcional: org/project no client (ex.: página de exemplo Sentry)
NEXT_PUBLIC_SENTRY_ORG=
NEXT_PUBLIC_SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
